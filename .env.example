# Google Gemini (FREE — get key from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=lyou-google-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOOP_INTERVAL_SECONDS=2.0

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
WEBSOCKET_URL=ws://localhost:8000/ws

# Camera
CAMERA_INDEX=0
CAMERA_FPS=10
ATTENTION_CHECK_INTERVAL=5

# Audio
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
STT_MODEL=base
AUDIO_DEVICE_INDEX=0
MIC_DEVICE_INDEX=0
ENABLE_MIC=true
VAD_ENERGY_THRESHOLD=500.0
VAD_SILENCE_DURATION=1.5

# AI Models
YOLO_MODEL=yolov8n.pt
EMBEDDING_MODEL=all-MiniLM-L6-v2
DISTRACTION_THRESHOLD=0.3

# Database
DATABASE_URL=sqlite:///./data/lecturer.db
CHROMA_PATH=./data/chroma_db

# Lecture Settings
MAX_LECTURE_DURATION=3600
LECTURE_LANGUAGE=en
DEFAULT_DIFFICULTY=intermediate

# Demo Mode — set DEMO_MODE=true for expo demos without real hardware.
# Mock camera generates synthetic student detections, mock mic injects
# scripted questions, and 5 demo students are auto-seeded on startup.
DEMO_MODE=false
