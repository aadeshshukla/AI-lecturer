# Google Gemini (FREE — get key from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_free_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
WEBSOCKET_URL=ws://localhost:8000/ws

# Camera
CAMERA_INDEX=0
CAMERA_FPS=10
ATTENTION_CHECK_INTERVAL=5

# Audio
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
STT_MODEL=base
AUDIO_DEVICE_INDEX=0
MIC_DEVICE_INDEX=0

# AI Models
YOLO_MODEL=yolov8n.pt
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database
DATABASE_URL=sqlite:///./data/lecturer.db
CHROMA_PATH=./data/chroma_db

# Lecture Settings
MAX_LECTURE_DURATION=3600
LECTURE_LANGUAGE=en
DEFAULT_DIFFICULTY=intermediate

# Demo Mode (set to true to use mock camera/mic — no real hardware needed)
DEMO_MODE=false
